alias lr="cd ~/ledgerrun && ls -lGh"
alias lrf="cd ~/ledgerrun/frontend"
alias lrb="cd ~/ledgerrun/backend && ls -lGh"
alias lri="cd ~/ledgerrun/infrastructure-ledgerrun && ls -lGh"
alias lrm="cd ~/ledgerrun/terraform-modules"

_tmux_session() {
  local SESSION=$1
  local SESSION_HOME=$2
  local DISPLAY_NAME=${3:-$SESSION}
  
  # Check if tmux is installed
  if ! command -v tmux &>/dev/null; then
    echo "Tmux not found.. exiting..."
    return 1
  fi
  
  if tmux ls | grep -q "^$SESSION:"; then
    # Session is running, attach to existing session
    echo "Attaching to $DISPLAY_NAME session . . ."
    tmux attach -t $SESSION
  else
    # Session does not exist, create new session
    echo "Creating new tmux session, '$SESSION' . . ."
    tmux new-session -s $SESSION -c $SESSION_HOME
  fi
}

# Alias functions
tala() {
  _tmux_session "tala" "$HOME/ledgerrun" "Ledger Run"
}

taf() {
  _tmux_session "taf" "$HOME/ledgerrun/frontend" "Ledger Run Frontend"
}

tab() {
  _tmux_session "tab" "$HOME/ledgerrun/backend" "Ledger Run Backend"
}
